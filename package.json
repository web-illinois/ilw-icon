{
    "name": "@illinois-toolkit/ilw-icon",
    "description": "A wrapper class to pull the icons from https://cdn.brand.illinois.edu/icons.html",
    "repository": "github:bryanjonker-illinois/ilw-icon",
    "private": false,
    "license": "MIT",
    "version": "1.1.0",
    "type": "module",
    "files": [
        "src/**",
        "dist/**",
        "builder/**"
    ],
    "exports": {
        ".": {
            "import": "./dist/ilw-icon.js",
            "require": "./dist/ilw-icon.cjs",
            "default": "./dist/ilw-icon.js"
        },
        "./ilw-icon.css": {
            "import": "./dist/ilw-icon.css"
        },
        "./ilw-icon.json": {
            "import": "./dist/ilw-icon.json"
        },
        "./fonts/*": {
            "import": "./dist/fonts/*"
        }
    },
    "main": "./dist/ilw-icon.js",
    "module": "./dist/ilw-icon.js",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build --config vite.transpile.config.ts --emptyOutDir && vite build --config vite.build.config.ts --emptyOutDir && cp -R ./src/fonts ./dist/fonts && cp ./src/ilw-icon.json ./dist/ilw-icon.json && cp -R ./src/fonts ./dist/cdn/fonts && cp ./src/ilw-icon.json ./dist/cdn/ilw-icon.json",
        "preview": "vite preview",
        "prepack": "npm run build",
        "fonts": "node --experimental-strip-types icon-font.ts",
        "test:axe": "playwright test",
        "test:axe:github": "playwright test --config playwright.ci.config.ts",
        "test": "vitest run --browser.headless",
        "test: browser": "vitest browser --browser chromium"
    },
    "dependencies": {
        "lit": "3.1.3"
    },
    "devDependencies": {
        "@illinois-toolkit/ilw-core": "^1.0.3",
        "typescript": "^5.9.2",
        "vite": "^7.1.3",
        "vite-plugin-dts": "^4.5.4",
        "fantasticon": "^3.0.0",
        "@axe-core/playwright": "^4.10.2",
        "@playwright/test": "^1.54.1",
        "axe-html-reporter": "^2.2.11",
        "playwright": "^1.54.1",
        "@vitest/browser": "^3.2.4",
        "vitest-browser-lit": "^0.1.0"
    }
}